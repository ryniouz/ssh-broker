{
  "appId": "com.ryniouz.sshbroker",
  "appName": "SSH Broker",
  "webDir": "www",
  "backgroundColor": "#0f1216",
  "server": {
    "androidScheme": "http",
    "cleartext": true,
    "allowNavigation": ["10.11.15.10", "10.11.15.11"]
  },
  "android": { "backgroundColor": "#0f1216" },
