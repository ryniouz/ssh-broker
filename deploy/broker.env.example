# Copy to deploy/broker.env on the server and fill in. NEVER commit broker.env.
# The SSH target is NOT set here — an admin acquires it after first login via the
# web UI (Settings -> Acquire SSH key). No server login/SSH creds live in this repo.
# ---------------------------------------------------------------------------

# Shared secret used by the web UI to manage plugins + acquire the SSH key.
# Generate one:  openssl rand -hex 32
BROKER_ADMIN_TOKEN=

# Signs the web dashboard's session cookies.  openssl rand -hex 32
WEB_SESSION_SECRET=

# --- networking (macvlan) ---
# unraid custom network name (br0/br1) or your macvlan network name.
NET_NAME=br1
API_IP=10.11.15.10
WEB_IP=10.11.15.11

# --- storage (keep separate from the git checkout) ---
DATA_DIR=/mnt/user/appdata/ssh-broker-data

# Image tag to build/run (optional).
IMAGE_TAG=1.3.4
