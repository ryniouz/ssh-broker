# Copy to deploy/broker.env on the server and fill in. NEVER commit broker.env.
# ---------------------------------------------------------------------------

# The host the broker manages. Because the containers run ON the unraid box,
# this is the unraid host's own LAN IP.
BROKER_SSH_HOST=10.10.2.3
BROKER_SSH_USER=root

# Shared secret used by the web UI + CLI to manage plugins over the API.
# Generate one:  openssl rand -hex 32
BROKER_ADMIN_TOKEN=

# Signs the web dashboard's session cookies.  openssl rand -hex 32
WEB_SESSION_SECRET=

# --- networking (macvlan) ---
# unraid custom network name (br0/br1) or your macvlan network name.
NET_NAME=br1
API_IP=10.11.20.1
WEB_IP=10.11.20.2

# --- storage ---
# Keep DATA_DIR separate from the git checkout, or runtime data (sqlite/keys)
# would collide with the source tree's api/ web/ folders.
DATA_DIR=/mnt/user/appdata/ssh-broker-data
SSH_KEY_FILE=/mnt/user/appdata/ssh-broker-data/secrets/broker_ssh_key
